# Azure AI Foundry
# Get from https://ai.azure.com -> Your Project -> Settings -> Connection String
AZURE_AI_PROJECT_CONNECTION_STRING=your-connection-string-here

# Optional: skip re-uploading docs if you've already set them up once
# FOUNDRY_AGENT_ID=
# FOUNDRY_VECTOR_STORE_ID=

# USDA NASS API (free)
# Register at https://quickstats.nass.usda.gov/api
USDA_NASS_API_KEY=your-free-key-here

# Docker Hub (for pushing images)
DOCKERHUB_USERNAME=your-dockerhub-username
